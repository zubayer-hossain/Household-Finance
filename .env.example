# Copy to `.env.local` for local Next.js (`npm run dev`).
# Keys marked [CLIENT] are embedded in the browser bundle — treat as non-secret identifiers only.

# [CLIENT] Supabase project URL (Authentication + PostgREST)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# [CLIENT] Supabase anon (public) key — safe with Row Level Security; never use for admin tasks in the UI
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# [SERVER ONLY] Service role bypasses RLS — use ONLY in Route Handlers / server code (invite, profile sync).
# Never prefix with NEXT_PUBLIC_; never import into client components or commit real values publicly.
SUPABASE_SERVICE_ROLE_KEY=

# [CLIENT] Fallback base URL for invitation email redirects when the API cannot derive origin from the request.
# Include scheme and host only (no trailing path). localhost is fine during development.
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
